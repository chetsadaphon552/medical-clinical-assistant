# --- Typhoon (iApp / OpenTyphoon) Configuration ---
# Get your API key from: https://iapp.co.th
QWEN_API_KEY=your_typhoon_api_key_here

# Model Settings
QWEN_MODEL=typhoon-v2.5-30b-instruct
QWEN_BASE_URL=https://api.opentyphoon.ai/v1

# --- Embedding Configuration -----
# Model used for RAG (HuggingFace model ID)
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
